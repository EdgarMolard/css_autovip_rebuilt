# AutoVip Configuration - Example File
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env to version control

# ==========================================
# Application Settings
# ==========================================

# Titre de la page affiché dans le navigateur
TITLE=Last Fate - AutoVip

# Logo/Titre affiché sur le site
LOGO_TITLE=Last Fate

# Nom du site (utilisé dans les mails et pages)
NOM_SITE=Vip - LastFate

# Nom de votre équipe/communauté
NOM_TEAM=LastFate

# ==========================================
# URLs Configuration
# ==========================================

# URL principal du site (IMPORTANT: HTTP ou HTTPS, pas les deux)
URL_SITE=https://vip.lastfate.fr

# Lien de votre forum (0 si aucun)
URL_FORUM=https://forum.lastfate.fr

# Lien de votre SourceBans (0 si aucun)
URL_SOURCEBANS=https://bans.lastfate.fr

# Lien de votre TeamSpeak (0 si aucun)
URL_TS3=https://ts.lastfate.fr

# Lien de votre serveur Discord (0 si aucun)
URL_DISCORD=https://discord.gg/atFqwdG

# Lien du groupe Steam de votre communauté (0 si aucun)
GROUPE_STEAM=https://steamcommunity.com/groups/lastfatefan

# Email de contact (0 si vide)
MAIL_CONTACT=contact@lastfate.fr

# ==========================================
# Database Configuration
# ==========================================

# Host de la base de données MySQL
SQL_HOST=localhost

# Utilisateur de la base de données
SQL_USER=Autovip

# Mot de passe de la base de données
SQL_PASSWORD=Autovip

# Nom de la base de données
SQL_BDD=Autovip

# Préfixe des tables AutoVip
SQL_PREFIX=af

# Préfixe des tables SourceBans
SB_PREFIX=sb

# Préfixe des admins sur SourceBans
ADMIN_PREFIX_SB=[VIP]

# Suffixe des admins sur SourceBans (laissez vide si aucun)
ADMIN_FIN_PSEUDO_SB=

# ==========================================
# Email Configuration
# ==========================================

# Nom de l'auteur des mails envoyés
MAIL_AUTEUR=LastFate - AutoVip

# Email d'expédition pour les mails (noreply)
MAIL_REPLY=noreply@lastfate.fr

# Envoyer un mail lors de l'inscription (1 = Activé, 0 = Désactivé)
MAIL_INSCRIPTION=1

# Titre du mail de bienvenue à l'inscription
MAIL_INSCRIPTION_TITLE=Bienvenue sur notre AutoVIP

# ==========================================
# Steam OpenID Configuration
# ==========================================

# Clé API Steam (obtenir sur https://steamcommunity.com/dev/apikey)
# Laissez vide pour désactiver l'authentification Steam
STEAM_API_KEY=

# Activer l'authentification Steam OpenID (1 = Activé, 0 = Désactivé)
STEAM_OPENID_ENABLED=1

# Steam ID du propriétaire du site (aura tous les droits - admin level 10)
# Format: STEAM_1:X:XXXXXXXX
ROOT_SITE=STEAM_1:1:175727273

# ==========================================
# Registration Settings
# ==========================================

# Accepter les nouvelles inscriptions (1 = Oui, 0 = Non)
ALLOW_REGISTER=1

# Nombre maximum d'inscriptions par IP
MAX_REGISTER_IP=2

# Délai avant de pouvoir refaire une demande de récupération de mot de passe (en secondes)
# Mettez 0 si vous ne souhaitez pas cette protection
DELAY_RECOVERY_PASSE=300

# ==========================================
# Pricing Configuration
# ==========================================

# Nombre de tokens à payer pour être géo (accès sur tous les serveurs VIP + ADMIN)
# Mettez 0 si vous ne souhaitez pas d'offres géo
TOKEN_GEO=0

# ==========================================
# Admin Levels (1 à 5, plus ROOT pour accès complet)
# ==========================================

# Level minimum pour accéder à la gestion des news
LVL_NEWS=3

# Level minimum pour accéder à la gestion des admins
LVL_GESTION_ADMIN=3

# Level minimum pour accéder à la gestion des tokens
LVL_GESTION_TOKEN=3

# Level minimum pour accéder aux logs
LVL_GESTION_LOGS=4

# Level minimum pour accéder à la gestion des serveurs
LVL_GESTION_SERVEURS=5

# Level minimum pour ajouter/modifier des admins du site
LVL_GESTION_SITEADMINS=4

# ==========================================
# Allopass Payment Gateway
# ==========================================

# Activer le paiement par Allopass (1 = Oui, 0 = Non)
ALLOPASS_PAIEMENT=0

# IDS Allopass
ALLOPASS_IDS=341287

# IDD Allopass
ALLOPASS_IDD=1497877

# AuthID Allopass (informations complètes de votre document)
ALLOPASS_AUTHID=xx/xx/xx

# Code de test Allopass (permet de ne pas bloquer le code de test)
ALLOPASS_CODETEST=pokemon

# ==========================================
# StarPass Payment Gateway
# ==========================================

# Activer le paiement par StarPass (1 = Oui, 0 = Non)
STARPASS_PAIEMENT=1

# IDP StarPass
STARPASS_IDP=61332

# IDD StarPass
STARPASS_IDD=397915

# Code de test StarPass
STARPASS_CODETEST=ch18a10n

# ==========================================
# PayPal Payment Gateway
# ==========================================

# Activer le paiement par PayPal (1 = Oui, 0 = Non)
PAYPAL_PAIEMENT=1

# Email PayPal qui recevra les paiements
PAYPAL_MAIL=paypal@lastfate.fr

# Devise PayPal (EUR / USD / GBP / etc)
PAYPAL_CURRENCY=EUR

# === Offre 1 Token ===
# Prix de l'offre 1 token
PAYPAL_PRIX_1=1.25
# Nombre de tokens pour cette offre
PAYPAL_TOKEN_1=1

# === Offre 3 Tokens ===
PAYPAL_PRIX_2=3.50
PAYPAL_TOKEN_2=3

# === Offre 6 Tokens ===
PAYPAL_PRIX_3=6.00
PAYPAL_TOKEN_3=6

# === Offre 12 Tokens ===
PAYPAL_PRIX_4=10.00
PAYPAL_TOKEN_4=12

# === Offre VIP à vie ===
PAYPAL_PRIX_5=30.00
PAYPAL_TOKEN_5=999

# ==========================================
# Rentabiliweb Configuration (Monnaie virtuelle)
# ==========================================

# Activer le paiement par Rentabiliweb (1 = Oui, 0 = Non)
RENTABILIWEB_PAIEMENT=0

# Hash de la page callback Rentabiliweb
RENTABILIWEB_HASH=xxx

# DocID Rentabiliweb
RENTABILIWEB_DOCID=116069

# SiteID Rentabiliweb
RENTABILIWEB_SITEID=393913

# Nombre de mini-tokens nécessaires pour obtenir 1 token
MINITOKEN_CONVERSION=110

